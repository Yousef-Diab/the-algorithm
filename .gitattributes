# index.html is generated by build.py, which writes LF. Force the working tree
# to LF too so a rebuild never shows a spurious whole-file line-ending diff.
# Mark it generated so GitHub collapses it in diffs/reviews.
index.html text eol=lf linguist-generated=true

# Keep the build inputs LF as well, for the same reason (build reads them verbatim).
*.py   text eol=lf
*.js   text eol=lf
*.html text eol=lf
